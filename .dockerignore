# Mirror of .gitignore + extras for Docker build context

.env
.env.*
*.db
*.db-*
data/
# Bundled map assets live under src/.../maps/data and MUST stay in the build context
# (the broad data/ rule above must not strip them).
!src/parcel_tracker/maps/data
!src/parcel_tracker/maps/data/**
plugins/*
!plugins/README.md
docker-compose.override.yml

__pycache__/
*.pyc
*.pyo
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
coverage.xml

logs/
*.log
backup/
*.bak
*.tar.gz

.vscode/
.idea/
*.swp
.DS_Store

# Dev-only files (NOT needed in production image)
tests/
docs/
.github/
.pre-commit-config.yaml
.editorconfig

# Git
.git/
.gitignore
.gitattributes
