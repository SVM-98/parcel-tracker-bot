# ─── Telegram (REQUIRED) ───────────────────────────────────────────
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your Telegram user ID (immutable bot owner)
# Get it from @userinfobot
OWNER_ID=

# Optional comma-separated list of additional authorized user IDs
# Users can also be added at runtime via /adduser command
ALLOWED_USER_IDS=

# ─── Tracking behavior ─────────────────────────────────────────────
# Standard check interval (minutes)
CHECK_INTERVAL_MINUTES=30

# Urgent check interval (minutes) — for parcels in transit / out for delivery
URGENT_CHECK_INTERVAL_MINUTES=10

# Maximum consecutive errors per parcel before deactivation
MAX_CONSECUTIVE_ERRORS=10

# Auto-archive parcels N hours after delivery
AUTO_ARCHIVE_HOURS=48

# Maximum active shipments per user
MAX_ACTIVE_SHIPMENTS=20

# ─── Database ──────────────────────────────────────────────────────
DATABASE_PATH=/app/data/bot.db

# ─── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO

# Hash tracking IDs in logs/metrics for privacy (recommended in production)
LOG_FULL_TRACKING_ID=false

# ─── i18n ──────────────────────────────────────────────────────────
# Default language (ISO 639-1). Users can override with /lang
DEFAULT_LANGUAGE=en

# ─── HTTP / Scraping ───────────────────────────────────────────────
REQUEST_TIMEOUT=30
REQUEST_DELAY_MIN=3
REQUEST_DELAY_MAX=8

# ─── Tracker health / quarantine (Plan 2 feature B) ────────────────
QUARANTINE_3FAIL_HOURS=1
QUARANTINE_6FAIL_HOURS=6
QUARANTINE_12FAIL_HOURS=24

# ─── 17track (universal fallback API) ──────────────────────────────
# Register at https://www.17track.net/en/apiuser
TRACK17_API_KEY=

# ─── DHL Express API (optional) ────────────────────────────────────
# Register at https://developer.dhl.com
# DHL_API_KEY=

# ─── UPS API (optional) ────────────────────────────────────────────
# Register at https://developer.ups.com
# UPS_CLIENT_ID=
# UPS_CLIENT_SECRET=

# ─── FedEx API (optional) ──────────────────────────────────────────
# Register at https://developer.fedex.com
# FEDEX_API_KEY=
# FEDEX_SECRET_KEY=

# ─── Observability (Plan 2 feature L) ──────────────────────────────
METRICS_ENABLED=true
METRICS_BIND_HOST=0.0.0.0             # Use 127.0.0.1 to bind localhost-only
METRICS_PORT=9090
LOG_FORMAT=json                       # 'json' for production, 'console' for dev

# ─── Telegram admin allowlist (Plan 2) ─────────────────────────────
# Comma-separated user IDs. Required for /health reset <tracker> command.
ADMIN_USER_IDS=

# ─── Scheduler — parallel batch (Plan 2 feature d) ─────────────────
BATCH_SIZE=10

# ─── Scheduler — per-tracker rate limiter (token bucket) ───────────
RATE_LIMIT_DEFAULT_PER_MIN=10
# Per-tracker overrides: RATE_LIMIT_TRACKER_<UPPERCASE_NAME>=<int>
# Example:
# RATE_LIMIT_TRACKER_TRACK17=30
# RATE_LIMIT_TRACKER_DHL=60

# ─── Scheduler — dynamic interval per ShipmentStatus (Plan 2) ──────
# Minutes; 0 = stop polling. Defaults applied if env not set:
#   STATUS_INTERVAL_NOT_FOUND=60
#   STATUS_INTERVAL_INFO_RECEIVED=60
#   STATUS_INTERVAL_PICKUP=30
#   STATUS_INTERVAL_IN_TRANSIT=15
#   STATUS_INTERVAL_OUT_FOR_DELIVERY=5
#   STATUS_INTERVAL_CUSTOMS=30
#   STATUS_INTERVAL_DELIVERED=0
#   STATUS_INTERVAL_UNDELIVERED=30
#   STATUS_INTERVAL_EXCEPTION=30
#   STATUS_INTERVAL_RETURNED=60
#   STATUS_INTERVAL_EXPIRED=0
#   STATUS_INTERVAL_ALERT=30

# ─── Notifications (Plan 2 feature D) ──────────────────────────────
NOTIFY_COOLDOWN_MINUTES=60
