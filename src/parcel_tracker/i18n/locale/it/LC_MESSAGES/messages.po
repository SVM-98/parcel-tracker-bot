"Send: <code>/remove CODE</code>\n"
"Example: <code>/remove 1Z999AA10123456784</code>"
msgstr ""
"🗑 <b>Rimuovi un pacco</b>\n"
"\n"
"Invia: <code>/remove CODICE</code>\n"
"Esempio: <code>/remove 1Z999AA10123456784</code>"

#: src/parcel_tracker/bot/messages.py:233
msgid ""
"✏️ <b>Rename a parcel</b>\n"
"\n"
"Send: <code>/rename CODE NEW_NAME</code>\n"
"Example: <code>/rename 1Z999AA10123456784 amazon order</code>"
