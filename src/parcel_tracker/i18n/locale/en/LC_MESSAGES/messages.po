#: src/parcel_tracker/bot/messages.py:191
msgid ""
"➕ <b>Add a parcel</b>\n"
"\n"
"Just paste the tracking number here — I'll detect the carrier automatically.\n"
"\n"
"You can also use:\n"
"<code>/add CODE [name]</code>\n"
"Example: <code>/add 1Z999AA10123456784 new phone</code>\n"
"\n"
"Right after adding, I'll ask you for a name so the parcel is easy to recognise."
msgstr ""
"➕ <b>Add a parcel</b>\n"
"\n"
"Just paste the tracking number here — I'll detect the carrier automatically.\n"
"\n"
"You can also use:\n"
"<code>/add CODE [name]</code>\n"
"Example: <code>/add 1Z999AA10123456784 new phone</code>\n"
"\n"
"Right after adding, I'll ask you for a name so the parcel is easy to recognise."

#: src/parcel_tracker/bot/messages.py:204
msgid ""
"🔍 <b>Parcel status</b>\n"
"\n"
"Send: <code>/status CODE</code>\n"
"Example: <code>/status 1Z999AA10123456784</code>\n"
"\n"
"Tip: use 📋 Parcel list to see all your codes."
msgstr ""
"🔍 <b>Parcel status</b>\n"
"\n"
