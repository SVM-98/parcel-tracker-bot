#: src/parcel_tracker/bot/messages.py:17
msgid ""
"📦 <b>Parcel Tracker Bot</b>\n"
"\n"
"Track your parcels and get smart notifications with maps.\n"
"\n"
"<b>Quick start:</b>\n"
"• Just send a tracking number to start tracking it\n"
"• Press /menu for everything else (buttons)"
msgstr ""
"📦 <b>Parcel Tracker Bot</b>\n"
"\n"
"Track your parcels and get smart notifications with maps.\n"
"\n"
"<b>Quick start:</b>\n"
"• Just send a tracking number to start tracking it\n"
"• Press /menu for everything else (buttons)"

#: src/parcel_tracker/bot/messages.py:27
msgid ""
"📦 <b>Parcel Tracker Bot</b>\n"
"\n"
"• Send a tracking number → I track it automatically\n"
"• /menu — buttons for list, status, events, map, settings\n"
"• /list — your active parcels\n"
"• /help — this message"
msgstr ""
"📦 <b>Parcel Tracker Bot</b>\n"
"\n"
"• Send a tracking number → I track it automatically\n"
"• /menu — buttons for list, status, events, map, settings\n"
"• /list — your active parcels\n"
"• /help — this message"

